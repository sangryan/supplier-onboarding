# Copy this to .env on the server and fill in real values
# cp .env.production.template .env

# Server Configuration
PORT=8000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRE=7d

# Email — Resend HTTP API (https://resend.com)
# The server uses Resend's REST API (port 443) — no SMTP ports needed.
# EMAIL_PASSWORD = your Resend API key (starts with re_)
# EMAIL_FROM     = verified sender address
#   - Testing (no domain setup needed): onboarding@resend.dev
#   - Production: verify betika.com in Resend dashboard → DNS → then use noreply@betika.com
# EMAIL_HOST / EMAIL_PORT / EMAIL_USER are ignored when EMAIL_PASSWORD starts with re_
EMAIL_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# Frontend URL
CLIENT_URL=http://41.191.225.34:5054

# File Upload
MAX_FILE_SIZE=20971520
UPLOAD_PATH=/app/uploads

# Company Details
COMPANY_NAME=Betika
COMPANY_EMAIL=procurement@betika.com
